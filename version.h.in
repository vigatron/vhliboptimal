#ifndef VHLIB_OPTIMAL_VERSION_H
#define VHLIB_OPTIMAL_VERSION_H

#define VHLIB_OPTIMAL_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define VHLIB_OPTIMAL_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define VHLIB_OPTIMAL_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define VHLIB_OPTIMAL_VERSION_HEX ((VHLIB_OPTIMAL_VERSION_MAJOR * 10000) + \
                                    (VHLIB_OPTIMAL_VERSION_MINOR * 100) + \
                                     VHLIB_OPTIMAL_VERSION_PATCH)

#endif // VHLIB_OPTIMAL_VERSION_H
